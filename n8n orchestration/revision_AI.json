    {
      "parameters": {
        "jsCode": "// Error handler — mirrors app.py error handling\nconst errorMsg = $json.error?.message || $json.errorMessage || 'Unknown error';\n\nlet userMessage = '';\n\nif (errorMsg.includes('429') || errorMsg.includes('RESOURCE_EXHAUSTED')) {\n  userMessage = '⚠️ **API Quota Exceeded**: The Gemini API free tier limit has been reached. Please wait a few minutes and try again, or upgrade your API plan.';\n} else if (errorMsg.includes('401') || errorMsg.includes('UNAUTHENTICATED')) {\n  userMessage = '🔑 **Authentication Error**: Please check your Google API Key in n8n credentials.';\n} else {\n  userMessage = `❌ **Error**: ${errorMsg}`;\n}\n\nreturn [{ json: { output: userMessage } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [200, 200],
